# wallBroken.obj — pared derruida (3 secciones, cortes diagonales)
# Base: x=0-1.0, y=0-1.0, z=0-0.2
# Sección L: x=0-0.38, top-izq=1.85, top-der=1.50 (diagonal)
# Hueco 1: x=0.38-0.48 (expone base superior)
# Sección M: x=0.48-0.60, top-izq=1.25, top-der=1.15 (diagonal)
# Hueco 2: x=0.60-0.68 (expone base superior)
# Sección R: x=0.68-1.0, top-izq=1.55, top-der=1.30 (diagonal)

mtllib wallBroken.mtl

# ---- VERTICES ----
# Base (8)
v 0.0   0.0  0.0
v 1.0   0.0  0.0
v 1.0   1.0  0.0
v 0.0   1.0  0.0
v 0.0   0.0  0.2
v 1.0   0.0  0.2
v 1.0   1.0  0.2
v 0.0   1.0  0.2

# Sección L — frente (9-11), detrás (12-14)
v  0.38  1.0   0.0
v  0.0   1.85  0.0
v  0.38  1.50  0.0
v  0.38  1.0   0.2
v  0.0   1.85  0.2
v  0.38  1.50  0.2

# Sección M — frente (15-18), detrás (19-22)
v  0.48  1.0   0.0
v  0.60  1.0   0.0
v  0.60  1.15  0.0
v  0.48  1.25  0.0
v  0.48  1.0   0.2
v  0.60  1.0   0.2
v  0.60  1.15  0.2
v  0.48  1.25  0.2

# Sección R — frente (23-25), detrás (26-28)
v  0.68  1.0   0.0
v  0.68  1.55  0.0
v  1.0   1.30  0.0
v  0.68  1.0   0.2
v  0.68  1.55  0.2
v  1.0   1.30  0.2

usemtl WallBroken

